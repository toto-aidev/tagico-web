# Tagico — 環境変数テンプレート（秘密情報なし・コミット対象）
# 実際の値を .env.local にコピーして入力する（.env.local は gitignore 対象）
# Vercel では Settings → Environment Variables に直接登録する（ファイル不要）

# Supabase（https://supabase.com → プロジェクト → Settings → API）
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# PostHog（https://posthog.com → Project Settings → Project API Key）
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
